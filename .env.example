# Environment Configuration Template
# Copy this to .env and fill in your values
# NEVER commit .env to version control

# Environment
FLASK_ENV=development
APP_ENV=development

# Database
DATABASE_URL=sqlite:///runs.db

# Admin
ADMIN_USER_ID=1

# Safety (CRITICAL: Set to false in production)
ALLOW_DB_INIT=true

# Debug
DEBUG=true
