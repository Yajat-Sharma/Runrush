# Environment Configuration Template
# Copy this to .env and fill in your values
# NEVER commit .env to version control

# Environment
FLASK_ENV=development
APP_ENV=development

# Database
# Local development (SQLite) — default if not set:
DATABASE_URL=sqlite:///runs.db

# Production (PostgreSQL on Render) — uncomment and fill:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Admin
ADMIN_USER_ID=1

# Safety (CRITICAL: Set to false in production)
ALLOW_DB_INIT=true

# Debug
DEBUG=true
